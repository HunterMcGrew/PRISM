{
  "clove": {
    "writes_report_to": ".prism/evidence/${runKey}/report.json",
    "preconditions": [
      {
        "id": "report-written",
        "description": "report.json written before stop",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/report.json"
        },
        "on_fail": "needs-replan"
      }
    ],
    "gates": [
      {
        "id": "types",
        "description": "TypeScript types pass",
        "checklist_key": "types",
        "source": "fresh",
        "check": {
          "kind": "command",
          "command": "{{commands.typecheck}}"
        },
        "on_fail": "done-override"
      },
      {
        "id": "lint",
        "description": "Crossref lint passes (prose cross-references, ADR refs, install surface links)",
        "checklist_key": "lint",
        "source": "fresh",
        "check": {
          "kind": "command",
          "command": "{{commands.lint}}"
        },
        "on_fail": "done-override"
      },
      {
        "id": "tests",
        "description": "Test suite passes",
        "checklist_key": "tests",
        "source": "ledger",
        "check": {
          "kind": "command",
          "command": "{{commands.test}}"
        },
        "on_fail": "done-override"
      }
    ],
    "unverifiable_boxes": [
      "code quality — whether Clove's implementation is correct, not just that types and tests pass",
      "design soundness — whether the approach matches the plan's intent"
    ],
    "allowed_routes": [
      "briar",
      "human",
      "clove",
      "winston",
      "eric"
    ],
    "ownership": {
      "may_write": [
        "src/**",
        "**/*.test.*",
        ".prism/plans/**",
        ".prism/evidence/**/report.json",
        ".ai-skills/skills/prism-code-dev/**",
        ".ai-skills/hooks/__smoke__/**",
        ".claude/hooks/__smoke__/**",
        ".claude/settings.json",
        ".gitignore",
        ".ai-skills/definitions/**"
      ],
      "may_not_run": [
        "gh pr merge",
        "git merge",
        "git push -f",
        "git push --force",
        "rm .prism/evidence",
        "rm -rf .prism/evidence",
        "rm -f .prism/evidence",
        "rm -fr .prism/evidence",
        "rm --force .prism/evidence"
      ]
    }
  },
  "sage": {
    "writes_report_to": ".prism/evidence/${runKey}/report.json",
    "preconditions": [
      {
        "id": "report-written",
        "description": "report.json written before stop",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/report.json"
        },
        "on_fail": "needs-replan"
      }
    ],
    "gates": [
      {
        "id": "tags-resolved",
        "description": "Both changelog tags verified via git rev-parse --verify (proof written by Sage after S1 validates both)",
        "checklist_key": "tags-resolved",
        "source": "fresh",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/tags-resolved.json"
        },
        "on_fail": "done-override"
      },
      {
        "id": "changelog-file-written",
        "description": "Changelog output file path recorded (Sage writes this sidecar on delivery)",
        "checklist_key": "changelog-file-written",
        "source": "fresh",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/changelog-path.txt"
        },
        "on_fail": "done-override"
      }
    ],
    "unverifiable_boxes": [
      "categorization accuracy — whether commits were placed in the correct category",
      "consolidation judgment — whether related commits were correctly merged into single entries"
    ],
    "allowed_routes": [
      "human"
    ],
    "ownership": {
      "may_write": [
        "CHANGELOG.md",
        "docs/**/*.md",
        "**/*.changelog.md",
        ".prism/evidence/**/report.json",
        ".prism/evidence/**/changelog-path.txt",
        ".prism/evidence/**/tags-resolved.json"
      ],
      "may_not_run": [
        "gh pr merge",
        "git merge",
        "git push -f",
        "git push --force"
      ]
    }
  },
  "atlas": {
    "writes_report_to": ".prism/evidence/${runKey}/report.json",
    "preconditions": [
      {
        "id": "report-written",
        "description": "report.json written before stop",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/report.json"
        },
        "on_fail": "needs-replan"
      }
    ],
    "gates": [
      {
        "id": "config-validates",
        "description": "config.json exists",
        "checklist_key": "config-validates",
        "source": "fresh",
        "check": {
          "kind": "file-exists",
          "path": ".ai-skills/config.json"
        },
        "on_fail": "done-override"
      }
    ],
    "unverifiable_boxes": [
      "detection accuracy — whether the detected stack matches the team's actual stack",
      "rule quality — whether generated rules reflect the team's real engineering standards"
    ],
    "allowed_routes": [
      "human",
      "winston"
    ],
    "ownership": {
      "may_write": [
        ".ai-skills/config.json",
        ".ai-skills/registry/**",
        ".prism/rules/**",
        ".ai-skills/skills/**",
        "AGENTS.md",
        ".prism/evidence/**/report.json"
      ],
      "may_not_run": [
        "gh pr merge",
        "git merge",
        "git push -f",
        "git push --force"
      ]
    }
  }
}
