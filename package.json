{
	"name": "@huntermcgrew/prism",
	"version": "0.7.2",
	"description": "PRISM — multi-team distributable AI toolkit (Claude / Codex / Cursor skill personas, rules, templates).",
	"author": "Hunter McGrew",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/HunterMcGrew/PRISM.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"files": [
		"dist/",
		"CHANGELOG.md",
		".prism/rules/",
		".prism/architect/",
		".prism/spec/",
		".prism/references/",
		".prism/templates/",
		".prism/SPEC.md",
		".prism/.sync-manifest.json",
		"templates/install/",
		".ai-skills/skills/",
		".ai-skills/definitions/roles.json",
		".ai-skills/definitions/paths.json",
		".ai-skills/config.json",
		".ai-skills/config.schema.json"
	],
	"bin": {
		"prism": "dist/cli.js"
	},
	"scripts": {
		"prism:adopt": "tsx scripts/ai-skills/adopt.ts",
		"prism:bootstrap": "tsx scripts/ai-skills/bootstrap-from-claude.ts",
		"prism:build": "tsx scripts/ai-skills/build.ts && pnpm run prism:test",
		"prism:bundle": "tsx scripts/ai-skills/bundle.ts",
		"prism:check": "tsx scripts/ai-skills/build.ts --check && pnpm run prism:check-types && pnpm run prism:test && pnpm run prism:verify-manifest && pnpm run prism:crossref-lint && pnpm run prism:verify-pack",
		"prism:check-types": "tsc --noEmit -p scripts/ai-skills/tsconfig.json",
		"prism:crossref-lint": "tsx scripts/ai-skills/crossref-lint.ts",
		"prism:doctor": "tsx scripts/ai-skills/doctor.ts",
		"prism:eject": "tsx scripts/ai-skills/eject.ts",
		"prism:migrate-skill": "tsx scripts/ai-skills/migrate-skill.ts",
		"prism:test": "tsx scripts/ai-skills/run-tests.ts",
		"prism:update": "tsx scripts/ai-skills/update.ts",
		"prism:verify-manifest": "tsx scripts/ai-skills/verify-manifest-coverage.ts",
		"prism:verify-pack": "tsx scripts/ai-skills/verify-pack-parity.ts",
		"prepublishOnly": "pnpm run prism:bundle && pnpm run prism:build && pnpm run prism:check"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"esbuild": "^0.28.1",
		"tsx": "^4.20.3",
		"typescript": "^5.6.3"
	},
	"engines": {
		"node": ">=20.10.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
