.DS_Store
*.swp
node_modules/

# PRISM build outputs — committed-vs-ignored split per `.ai-skills/docs/compatibility.md § Per-Tool Directory Ownership`.
# `.agents/` is the per-user Codex skills root — fully ignored.
/.agents/
# `.codex/codex-config.toml` is a per-user file (personality, projects, marketplaces) — committing it would clobber consumer customization.
/.codex/codex-config.toml
# Per-tool worktree state is operational, not generated — ignored on every tool namespace.
.claude/worktrees/
.codex/worktrees/
.cursor/worktrees/
# Per-user local overrides — ignored.
.claude/settings.local.json


# Theo state files — operational; gitignored per ADR-0040 + Theo state schema
.prism/theo-state.json
.prism/theo-state.json.tmp

# Ren state files — operational; gitignored per ADR-0042 + Ren state schema
.prism/ren-state.json
.prism/ren-state.json.tmp

# Sol/Conductor state files — operational; gitignored per the conductor goal-state schema.
# The glob covers the timestamped archive/broken variants the corruption-recovery and
# resume protocols write (conductor-state.<timestamp>.json, .<timestamp>.broken.json).
.prism/conductor-state.json
.prism/conductor-state.json.tmp
.prism/conductor-state.*.json
