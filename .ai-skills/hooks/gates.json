    "writes_report_to": ".prism/evidence/${runKey}/report.json",
    "preconditions": [
      {
        "id": "report-written",
        "description": "report.json written before stop",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/report.json"
        },
        "on_fail": "needs-replan"
      },
      {
        "id": "retro-report-exists",
        "description": "At least one retro report file exists under .prism/retros/ — Iris deliverable is the saved report",
        "check": {
          "kind": "command",
          "command": "ls .prism/retros/*.md 2>/dev/null | head -1 | grep -q ."
        },
        "on_fail": "needs-replan"
      }
    ],
    "gates": [],
    "unverifiable_boxes": [
      "evidence completeness — whether all relevant plan sections were scanned before staging voices",
      "divergence accuracy — whether staged disagreements reflect genuine Decision-vs-outcome conflicts vs adjacent issues"
    ],
    "allowed_routes": [
      "nora",
      "human"
    ],
    "ownership": {
      "may_write": [
        ".prism/retros/**",
        ".prism/iris-state.json",
        ".prism/evidence/**/report.json"
      ],
      "may_not_run": [
        "gh pr merge",
        "git merge",
        "git push -f",
        "git push --force",
        "rm .prism/evidence",
        "rm -rf .prism/evidence",
        "rm -f .prism/evidence",
        "rm -fr .prism/evidence",
        "rm --force .prism/evidence"
      ]
    }
  },
  "lilac": {
    "writes_report_to": ".prism/evidence/${runKey}/report.json",
    "preconditions": [
      {
        "id": "report-written",
        "description": "report.json written before stop",
        "check": {
          "kind": "file-exists",
          "path": ".prism/evidence/${runKey}/report.json"
        },
        "on_fail": "needs-replan"
      }
    ],
    "gates": [],
    "unverifiable_boxes": [
      "PR categorization accuracy — whether each PR landed in the correct Merged/In Review/Continued/Reviewed subsection",
      "window accuracy — whether the resolved time window matched the user intent"
    ],
    "allowed_routes": [
      "human"
    ],
    "ownership": {
      "may_write": [
        ".prism/evidence/**/report.json"
      ],
      "may_not_run": [
        "gh pr merge",
        "git merge",
        "git push -f",
        "git push --force",
        "rm .prism/evidence",
        "rm -rf .prism/evidence",
        "rm -f .prism/evidence",
        "rm -fr .prism/evidence",
        "rm --force .prism/evidence"
      ]
    }
  }
}
